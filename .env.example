# ──────────────────────────────────────────────────────────────
# FixFlow — environment variables
# Copy this file to `.env` for local dev, or add these in the
# Vercel dashboard (Project → Settings → Environment Variables).
# ──────────────────────────────────────────────────────────────

# REQUIRED — your OpenAI API key.
# Used ONLY by the /api/diagnose serverless function. It is read from
# process.env server-side and is NEVER exposed to the browser.
OPENAI_API_KEY=

# OPTIONAL — override the vision-capable model (defaults to gpt-4o).
# OPENAI_MODEL=gpt-4o

# OPTIONAL — reserved for a FUTURE release (parts-price lookups and
# tutorial scraping). NOT used by the MVP. Safe to leave blank.
APIFY_TOKEN=
